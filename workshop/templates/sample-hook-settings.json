{
  "_comment": "TEMPLATE: Example .claude/settings.json with hook configurations",
  "_note": "Students should create their own hooks, not copy this file directly",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-filename.sh",
            "_description": "Validates file naming conventions before creation"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto-lint.sh",
            "_description": "Runs linter after file is written"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if all requested changes were completed and if any test coverage was added for new functionality."
          }
        ]
      }
    ]
  }
}
